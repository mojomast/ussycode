# Caddyfile — managed by Ansible for ussycode
#
# This role keeps Caddy internal-only. nginx owns public :80/:443 and forwards
# traffic to {{ caddy_site_listen }}. ussycode mutates runtime config through the
# admin API on {{ caddy_admin_listen }} to add API, admin, VM, and custom-domain
# routes.
{
	admin {{ caddy_admin_listen }}
	auto_https off
	http_port 8085
	https_port 8443
}

http://{{ caddy_site_listen }} {
	respond /healthz 200
	respond "ussycode internal caddy" 200
}
