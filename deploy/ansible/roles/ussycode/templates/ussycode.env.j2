# /etc/ussycode/ussycode.env — managed by Ansible
# ussycode platform configuration
# See: https://github.com/mojomast/ussycode for documentation

# Core settings
USSYCODE_DOMAIN={{ ussycode_domain }}
USSYCODE_SSH_ADDR={{ ussycode_ssh_addr | default(':2222') }}
USSYCODE_HTTP_ADDR={{ ussycode_http_addr | default(':8080') }}
USSYCODE_DATA_DIR={{ ussycode_data_dir | default('/var/lib/ussycode') }}
USSYCODE_DB_PATH={{ ussycode_db_path | default('/var/lib/ussycode/ussycode.db') }}

# Caddy reverse proxy
USSYCODE_CADDY_ADMIN={{ ussycode_caddy_api | default('http://localhost:2019') }}
USSYCODE_CADDY_SITE={{ caddy_site_listen | default('127.0.0.1:8085') }}

# Storage
USSYCODE_STORAGE={{ ussycode_storage_backend | default('zfs') }}
USSYCODE_STORAGE_POOL={{ ussycode_zfs_pool | default('vmpool') }}

# VM defaults
USSYCODE_DEFAULT_IMAGE={{ ussycode_default_image | default('ussyuntu') }}
USSYCODE_DEFAULT_CPU={{ ussycode_default_cpu | default('1') }}
USSYCODE_DEFAULT_MEM={{ ussycode_default_mem | default('512') }}
USSYCODE_DEFAULT_DISK={{ ussycode_default_disk | default('5') }}
USSYCODE_MAX_VMS={{ ussycode_max_vms_per_user | default('5') }}

# Networking
USSYCODE_BRIDGE={{ ussycode_network_bridge | default('ussy0') }}
USSYCODE_SUBNET={{ ussycode_network_subnet | default('10.0.0.0/24') }}

# TLS / DNS
USSYCODE_TLS_EMAIL={{ ussycode_acme_email | default('') }}
USSYCODE_DNS_PROVIDER={{ ussycode_dns_provider | default('cloudflare') }}
USSYCODE_DNS_API_TOKEN={{ ussycode_dns_api_token | default('') }}

# VMM
USSYCODE_VMM=firecracker
USSYCODE_KERNEL={{ ussycode_data_dir | default('/var/lib/ussycode') }}/vmlinux
USSYCODE_FIRECRACKER_BIN=/usr/local/bin/firecracker
