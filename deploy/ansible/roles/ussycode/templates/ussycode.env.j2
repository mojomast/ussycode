# /etc/ussycode/ussycode.env — managed by Ansible
# ussycode platform configuration

# Core settings
USSYCODE_DOMAIN={{ ussycode_domain }}
USSYCODE_API_DOMAIN={{ ussycode_api_domain | default('') }}
USSYCODE_SSH_ADDR={{ ussycode_ssh_addr | default(':2222') }}
USSYCODE_HTTP_ADDR={{ ussycode_http_addr | default('127.0.0.1:8080') }}
USSYCODE_ADMIN_ADDR={{ ussycode_admin_addr | default('127.0.0.1:9090') }}
USSYCODE_METADATA_ADDR={{ ussycode_metadata_addr | default(':8083') }}
USSYCODE_AUTH_PROXY_ADDR={{ ussycode_auth_proxy_addr | default('127.0.0.1:9876') }}
USSYCODE_SMTP_ADDR={{ ussycode_smtp_addr | default(':2525') }}
USSYCODE_SMTP_RELAY={{ ussycode_smtp_relay | default('localhost:25') }}
USSYCODE_SMTP_FROM={{ ussycode_smtp_from | default('noreply@' ~ ussycode_domain) }}
USSYCODE_DATA_DIR={{ ussycode_data_dir | default('/var/lib/ussycode') }}
USSYCODE_DB_PATH={{ ussycode_db_path | default('/var/lib/ussycode/ussycode.db') }}
USSYCODE_SSH_HOST_KEY={{ ussycode_ssh_host_key | default((ussycode_data_dir | default('/var/lib/ussycode')) ~ '/ssh_host_ed25519_key') }}

# Internal reverse proxy
USSYCODE_CADDY_ADMIN={{ ussycode_caddy_api | default('http://localhost:2019') }}

# Storage
USSYCODE_STORAGE={{ ussycode_storage_backend | default('zfs') }}
USSYCODE_STORAGE_POOL={{ ussycode_zfs_pool | default('vmpool') }}

# VM defaults
USSYCODE_DEFAULT_IMAGE={{ ussycode_default_image | default('ussyuntu') }}
USSYCODE_DEFAULT_CPU={{ ussycode_default_cpu | default('1') }}
USSYCODE_DEFAULT_MEM={{ ussycode_default_mem | default('512') }}
USSYCODE_DEFAULT_DISK={{ ussycode_default_disk | default('5') }}
USSYCODE_MAX_VMS={{ ussycode_max_vms_per_user | default('5') }}

# Networking
USSYCODE_BRIDGE={{ ussycode_network_bridge | default('ussy0') }}
USSYCODE_SUBNET={{ ussycode_network_subnet | default('10.0.0.0/24') }}

# DNS / runtime proxy integration
USSYCODE_TLS_EMAIL={{ ussycode_acme_email | default('') }}
USSYCODE_DNS_PROVIDER={{ ussycode_dns_provider | default('cloudflare') }}
USSYCODE_DNS_API_TOKEN={{ ussycode_dns_api_token | default('') }}

# Firecracker / jailer
USSYCODE_VMM=firecracker
USSYCODE_KERNEL={{ ussycode_kernel_path | default((ussycode_data_dir | default('/var/lib/ussycode')) ~ '/vmlinux') }}
USSYCODE_FIRECRACKER_BIN={{ ussycode_firecracker_bin | default('/usr/local/bin/firecracker') }}
USSYCODE_JAILER_BIN={{ ussycode_jailer_bin | default('/usr/local/bin/jailer') }}
USSYCODE_JAILER_UID={{ ussycode_jailer_uid | default('30000') }}
USSYCODE_JAILER_GID={{ ussycode_jailer_gid | default('30000') }}
USSYCODE_CHROOT_BASE_DIR={{ ussycode_chroot_base_dir | default('/srv/jailer') }}

# Optional integrations
USSYCODE_LLM_ENCRYPT_SECRET={{ ussycode_llm_encrypt_secret | default('') }}
USSYCODE_ROUTUSSY_URL={{ ussycode_routussy_url | default('') }}
USSYCODE_ROUTUSSY_INTERNAL_KEY={{ ussycode_routussy_internal_key | default('') }}
USSYCODE_OTLP_ENDPOINT={{ ussycode_otlp_endpoint | default('') }}
